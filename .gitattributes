# Set default behavior to automatically handle line endings for text files
* text=auto

# Ensure gradlew has LF line endings on all platforms
gradlew text eol=lf
gradlew.bat text eol=crlf

# Force binary files to be treated as binary - strictly disabling any text/line-ending conversions
*.png -text -diff
*.jpg -text -diff
*.jpeg -text -diff
*.gif -text -diff
*.webp -text -diff
*.ico -text -diff
*.jar -text -diff
*.keystore -text -diff
